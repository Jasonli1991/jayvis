# ── 知識庫（SQLite，零伺服器；留空用預設 ~/.n/kb.sqlite）──
# KB_PATH=

# 資料來源（也可在控制台「記憶重灌」卡編輯）
OBSIDIAN_PATH=
# GitHub repos：逗號分隔 owner/repo；留空＝不追蹤 GitHub
GITHUB_REPOS=

# 檢索門檻
RETRIEVAL_THRESHOLD=0.3

# ── LLM 生成（模型名開頭決定供應商，金鑰填用得到的家即可）──
# gemini-* → Google：到 Google AI Studio 拿（有免費額度）
GEMINI_API_KEY=
# claude-* → Anthropic：console.anthropic.com
ANTHROPIC_API_KEY=
# gpt-*/o* → OpenAI：platform.openai.com
OPENAI_API_KEY=
# OpenAI 相容端點（如本地 Ollama：http://localhost:11434/v1，或第三方聚合商）
# 設了之後，非 gemini-*/claude-*/gpt-* 的模型名（gemma:12b、qwen3:8b 等）一律走此端點；
# 本地 Ollama 不需金鑰（OPENAI_API_KEY 可留空）
OPENAI_BASE_URL=
# 模型（兩種模式通用）
MODEL_GENERAL=gemini-2.5-flash
MODEL_CODE=gemini-2.5-pro
# 用自己的 GCP Vertex 時填寫（不設 GEMINI_API_KEY 時生效）
# GCP_PROJECT=
# GCP_LOCATION=global

# ── Telegram Bot API 助理（live 入口）──
TG_BOT_TOKEN=
# 擁有者的 TG 數字 id（唯一能觸發動作工具的人；0＝關）
OWNER_CHAT_ID=
ALLOWLIST_USER_IDS=

# ── Telegram MTProto（僅 tg_history_sync 離線灌檔用；同事通常免）──
TG_API_ID=
TG_API_HASH=

# ── 動作工具開關（一般用控制台「動作工具」卡開關；此處留作參考）──
# 媒體工具（圖片去背/轉檔/調尺寸）：需 pip install rembg；
# 文件(Word/PDF)轉檔另需 brew install --cask libreoffice（未裝時圖片功能照常）。
# MEDIA_ENABLED=false
